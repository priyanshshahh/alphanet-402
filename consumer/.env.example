# =====================================================================
# AlphaNet-402 — Consumer Agent (Privy + x402) Environment
# =====================================================================
# Copy to `.env`, then run `npm run login` to bind a Privy agent wallet.
# =====================================================================

# Privy application credentials (Dashboard -> App settings).
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Wallet the human authorized for this agent via `privy-agent-wallets login`.
# After login, copy the wallet id printed by the CLI (or from agents.privy.io).
PRIVY_AGENT_WALLET_ID=

# Provider (AlphaNet-402 Polymarket oracle) base URL + the paid endpoint.
PROVIDER_URL=http://localhost:8000
TRADE_ID=1

# Safety cap (USDC, 6 decimals): 1000000 = $1.00 max per request.
MAX_PAYMENT_BASE_UNITS=1000000
