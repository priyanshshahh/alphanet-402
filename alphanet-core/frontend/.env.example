# Backend origin for split deploys (Vercel frontend -> Render backend).
# Leave unset for same-origin / dev proxy.
# VITE_API_BASE=https://alphanet-402-api.onrender.com

# Optional: pitch deck "Demo" slide — YouTube watch URL, youtu.be short link, direct .mp4/.webm URL, or Loom share URL.
# If unset, the deck uses an embedded live `/demo/embed` unless you add `public/pitch-demo.mp4` or `public/pitch-demo.webm` (see `npm run record:demo`).
# VITE_PITCH_DEMO_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID
