# LIVE = real Tavily (402.tavily.com) via AWAL when TAVILY_API_KEY is unset; with a Tavily key, REST is used (no USDC scout).
# PAPER = offline scout only (no Tavily, no AWAL).
TRADING_MODE=LIVE
LOOP_INTERVAL_SECONDS=30

# Blockchain (Base Sepolia for hackathon — switch to eip155:8453 + mainnet USDC for production)
NETWORK_CAIP_ID=eip155:84532
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Appended to `npx awal x402 pay` (use "" if your CLI infers chain from the invoice only)
AWAL_X402_PAY_EXTRA=--chain base-sepolia

# Strict Agent Spending Limits & Guardrails
MAX_DAILY_SPEND_USDC=2.00
MAX_PRICE_PER_SEARCH_USDC=0.01
EDGE_THRESHOLD=0.05
DAILY_DRAWDOWN_LIMIT_USDC=5.00

# Tavily — pick ONE primary path for scouting:
# A) REST (plan credits, no USDC) — set TAVILY_API_KEY (takes priority over x402).
# B) x402 + AWAL (USDC) — leave TAVILY_API_KEY empty and set TRADING_MODE=LIVE.
TAVILY_API_KEY=
TAVILY_REST_ENDPOINT=https://api.tavily.com/search
TAVILY_402_ENDPOINT=https://402.tavily.com/v1/search

# Your Agentic Wallet (AWAL) EVM address — used as payTo on OUR 402 invoices and shown in the UI.
# For Tavily 402: this must be the SAME wallet `npx awal address` shows after `auth login` / `auth verify`
# (that session signs `npx awal x402 pay` — fund this address with test USDC on the chain you use).
OUR_AWAL_WALLET_ADDRESS=0x4b97f492232c6C285F0F3b60c38fc4a7Ee13d675

# Inference routing (Groq free tier = $0 LLM; use for NLP extraction only)
GROQ_API_KEY=your_free_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Azure OpenAI (GitHub Student Pack / Azure for Students)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Optional: Sentry student plan — error tracking for 402 / awal / loop failures
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Tickers the autonomous loop scouts each cycle (comma-separated)
WATCHLIST=BTC,ETH,SOL
