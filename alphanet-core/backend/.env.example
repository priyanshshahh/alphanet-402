# ============================================================
# AlphaNet-402 backend — copy to .env and fill in what you use.
# Everything runs keyless by default (yfinance + heuristic NLP).
# ============================================================

# PAPER = free data only (yfinance; Tavily REST if a key is set).
# LIVE  = additionally allow x402 USDC micropayments (`npx awal x402 pay`)
#         for Tavily news when no REST key is set.
TRADING_MODE=PAPER

# DEMO_MODE=1 replaces real market data with clearly-labeled synthetic
# headlines (every record carries demo:true). Never enabled by default.
DEMO_MODE=0

LOOP_INTERVAL_SECONDS=30

# Blockchain (Base Sepolia testnet default — eip155:8453 + mainnet USDC for production)
NETWORK_CAIP_ID=eip155:84532
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Appended to `npx awal x402 pay` (use "" if your CLI infers chain from the invoice only)
AWAL_X402_PAY_EXTRA=--chain base-sepolia

# Strict agent spending limits & guardrails
MAX_DAILY_SPEND_USDC=2.00
MAX_PRICE_PER_SEARCH_USDC=0.01
EDGE_THRESHOLD=0.05
DAILY_DRAWDOWN_LIMIT_USDC=5.00

# Tavily news layer (optional — yfinance covers prices/fundamentals keyless):
# A) REST (plan credits, no USDC) — set TAVILY_API_KEY (takes priority over x402).
# B) x402 + AWAL (USDC) — leave TAVILY_API_KEY empty and set TRADING_MODE=LIVE.
TAVILY_API_KEY=
TAVILY_REST_ENDPOINT=https://api.tavily.com/search
TAVILY_402_ENDPOINT=https://402.tavily.com/v1/search

# Your Agentic Wallet (AWAL) EVM address — payTo on OUR 402 invoices.
# REQUIRED to sell rationale over x402: the API refuses to issue invoices
# without it (no zero-address fallback). Must match `npx awal address`
# after `auth login`; fund it with test USDC on your chosen chain.
OUR_AWAL_WALLET_ADDRESS=

# Inference (Groq free tier = $0 LLM; NLP extraction only, never portfolio math).
# Leave empty to use the deterministic heuristic parser.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Sentry — error tracking for 402 / awal / loop failures
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Equity tickers the autonomous loop scouts each cycle (comma-separated)
WATCHLIST=AAPL,MSFT,NVDA

# Optional: override the sqlite file location (used by tests/deploys)
# ALPHANET_DB_PATH=/data/alphanet.db
